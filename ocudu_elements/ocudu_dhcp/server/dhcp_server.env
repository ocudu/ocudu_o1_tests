# Environment variables for DHCP4 server Docker container

# DHCPv4 settings for Kea 4 server
ETH_4=*

## Settings for leases
RENEW_TIMER_4=1000
REBIND_TIMER_4=2000
VALID_LIFETIME_4=4000

# IPv4 subnets settings for Kea server
SUBNET_IP_4=192.168.50.0/24
POOL_4=192.168.50.10-192.168.50.99
ROUTER_IP_4=0.0.0.0
DNS_IP_4=192.168.50.53
DOMAIN_NAME_4=oran.lab
NTP_SERVERS_4=192.168.50.123

## Static DHCP lease
MAC_ADDRESS_RESERVATION_4=aa:bb:cc:dd:ee:01
IP_ADDRESS_RESERVATION_4=192.168.50.11

# Variables for generating the DHCPv4 option 43 field (generate_option43_hex.sh script)
RU_CONTROLLER_IP_ADDRESS=192.255.255.255
RU_CONTROLLER_FQDN=testcontroller.oran.example
CALLHOME_SSH_OR_TLS=0x00 # 0x00=NETCONF/SSH, 0x01=NETCONF/TLS