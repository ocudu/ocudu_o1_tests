<!-- Main CU base config -->
<ManagedElement xmlns="urn:3gpp:sa5:_3gpp-common-managed-element">
  <id>ran1</id>
  <attributes>
    <priorityLabel>1</priorityLabel>
  </attributes>

  <GNBCUCPFunction xmlns="urn:3gpp:sa5:_3gpp-nr-nrm-gnbcucpfunction">
      <id>cucp1</id>
      <attributes>
        <gNBId>1</gNBId>
        <gNBIdLength>24</gNBIdLength>
        <gNBCUName>ocuducu1</gNBCUName>
        <pLMNId>
          <mcc>001</mcc>
          <mnc>01</mnc>
        </pLMNId>
        <priorityLabel>1</priorityLabel>
        <qceIdMappingInfoList>
          <idx>0</idx>
          <qoECollectionEntityAddress>0.0.0.0</qoECollectionEntityAddress>
          <qoECollectionEntityIdentity>unused</qoECollectionEntityIdentity>
          <pLMNTarget>
            <mcc>001</mcc>
            <mnc>01</mnc>
          </pLMNTarget>
        </qceIdMappingInfoList>
      </attributes>

      <RRMPolicyRatio xmlns="urn:3gpp:sa5:_3gpp-nr-nrm-rrmpolicy">
        <id>rrm_policy1</id>
        <attributes>
          <resourceType>DRB</resourceType>
          <rRMPolicyMemberList>
            <mcc>001</mcc>
            <mnc>01</mnc>
            <sd>ff:ff:ff</sd>
            <sst>1</sst>
          </rRMPolicyMemberList>
          <rRMPolicyMaxRatio>100</rRMPolicyMaxRatio>
          <rRMPolicyMinRatio>0</rRMPolicyMinRatio>
          <rRMPolicyDedicatedRatio>0</rRMPolicyDedicatedRatio>
        </attributes>
      </RRMPolicyRatio>

      <PerfMetricJob>
        <id>defaulttrace</id>
        <attributes>
          <administrativeState>UNLOCKED</administrativeState>
          <performanceMetrics>DRB.MaxActiveUeDl</performanceMetrics>
          <granularityPeriod>1</granularityPeriod>
          <!--
          <fileReportingPeriod>10</fileReportingPeriod>
          <fileLocation>/tmp/metrics.json</fileLocation>
          -->
          <streamTarget>http://192.168.2.42:9560/json</streamTarget>
        </attributes>
      </PerfMetricJob>

      <NRCellCU xmlns="urn:3gpp:sa5:_3gpp-nr-nrm-nrcellcu">
        <id>nrcellcu1</id>
        <attributes>
          <cellLocalId>0</cellLocalId>
          <pLMNInfoList>
            <mcc>001</mcc>
            <mnc>01</mnc>
            <sd>ff:ff:ff</sd>
            <sst>1</sst>
          </pLMNInfoList>
          <priorityLabel>1</priorityLabel>
          <ocudu_nrcellcu_mobility_extensions xmlns="urn:ocudu-gnbcucpfunction-mobility-extension:1.0">
            <periodic_report_cfg_id>1</periodic_report_cfg_id>
          </ocudu_nrcellcu_mobility_extensions>
        </attributes>
        <NRCellRelation xmlns="urn:3gpp:sa5:_3gpp-nr-nrm-nrcellrelation">
          <id>rel-0-to-1</id>
          <attributes>
            <nRFreqRelationRef>NRFreqRelation=intra-freq</nRFreqRelationRef>
            <adjacentNRCellRef>ManagedElement=ran1,GNBCUCPFunction=cucp1,NRCellCU=nrcellcu2</adjacentNRCellRef>
            <ocudu_nrcellrelation_mobility_extensions xmlns="urn:ocudu-gnbcucpfunction-mobility-extension:1.0">
              <report_config_refs>2</report_config_refs>
              <report_config_refs>3</report_config_refs>
              <report_config_refs>4</report_config_refs>
              <report_config_refs>5</report_config_refs>
            </ocudu_nrcellrelation_mobility_extensions>
          </attributes>
        </NRCellRelation>
        <NRCellRelation xmlns="urn:3gpp:sa5:_3gpp-nr-nrm-nrcellrelation">
          <id>rel-0-to-2</id>
          <attributes>
            <nRFreqRelationRef>NRFreqRelation=intra-freq</nRFreqRelationRef>
            <adjacentNRCellRef>ManagedElement=ran1,GNBCUCPFunction=cucp1,NRCellCU=nrcellcu3</adjacentNRCellRef>
            <ocudu_nrcellrelation_mobility_extensions xmlns="urn:ocudu-gnbcucpfunction-mobility-extension:1.0">
              <report_config_refs>2</report_config_refs>
            </ocudu_nrcellrelation_mobility_extensions>
          </attributes>
        </NRCellRelation>
      </NRCellCU>
      <NRCellCU xmlns="urn:3gpp:sa5:_3gpp-nr-nrm-nrcellcu">
        <id>nrcellcu2</id>
        <attributes>
          <cellLocalId>1</cellLocalId>
          <pLMNInfoList>
            <mcc>001</mcc>
            <mnc>01</mnc>
            <sd>ff:ff:ff</sd>
            <sst>1</sst>
          </pLMNInfoList>
          <priorityLabel>1</priorityLabel>
          <ocudu_nrcellcu_mobility_extensions xmlns="urn:ocudu-gnbcucpfunction-mobility-extension:1.0">
            <periodic_report_cfg_id>1</periodic_report_cfg_id>
          </ocudu_nrcellcu_mobility_extensions>
        </attributes>
        <NRCellRelation xmlns="urn:3gpp:sa5:_3gpp-nr-nrm-nrcellrelation">
          <id>rel-1-to-0</id>
          <attributes>
            <nRFreqRelationRef>NRFreqRelation=intra-freq</nRFreqRelationRef>
            <adjacentNRCellRef>ManagedElement=ran1,GNBCUCPFunction=cucp1,NRCellCU=nrcellcu1</adjacentNRCellRef>
            <ocudu_nrcellrelation_mobility_extensions xmlns="urn:ocudu-gnbcucpfunction-mobility-extension:1.0">
              <report_config_refs>2</report_config_refs>
            </ocudu_nrcellrelation_mobility_extensions>
          </attributes>
        </NRCellRelation>
        <NRCellRelation xmlns="urn:3gpp:sa5:_3gpp-nr-nrm-nrcellrelation">
          <id>rel-1-to-2</id>
          <attributes>
            <nRFreqRelationRef>NRFreqRelation=intra-freq</nRFreqRelationRef>
            <adjacentNRCellRef>ManagedElement=ran1,GNBCUCPFunction=cucp1,NRCellCU=nrcellcu3</adjacentNRCellRef>
            <ocudu_nrcellrelation_mobility_extensions xmlns="urn:ocudu-gnbcucpfunction-mobility-extension:1.0">
              <report_config_refs>2</report_config_refs>
            </ocudu_nrcellrelation_mobility_extensions>
          </attributes>
        </NRCellRelation>
      </NRCellCU>
      <NRCellCU xmlns="urn:3gpp:sa5:_3gpp-nr-nrm-nrcellcu">
        <id>nrcellcu3</id>
        <attributes>
          <cellLocalId>2</cellLocalId>
          <pLMNInfoList>
            <mcc>001</mcc>
            <mnc>01</mnc>
            <sd>ff:ff:ff</sd>
            <sst>1</sst>
          </pLMNInfoList>
          <priorityLabel>1</priorityLabel>
          <ocudu_nrcellcu_mobility_extensions xmlns="urn:ocudu-gnbcucpfunction-mobility-extension:1.0">
            <periodic_report_cfg_id>1</periodic_report_cfg_id>
          </ocudu_nrcellcu_mobility_extensions>
        </attributes>
        <NRCellRelation xmlns="urn:3gpp:sa5:_3gpp-nr-nrm-nrcellrelation">
          <id>rel-2-to-0</id>
          <attributes>
            <nRFreqRelationRef>NRFreqRelation=intra-freq</nRFreqRelationRef>
            <adjacentNRCellRef>ManagedElement=ran1,GNBCUCPFunction=cucp1,NRCellCU=nrcellcu1</adjacentNRCellRef>
            <ocudu_nrcellrelation_mobility_extensions xmlns="urn:ocudu-gnbcucpfunction-mobility-extension:1.0">
              <report_config_refs>2</report_config_refs>
            </ocudu_nrcellrelation_mobility_extensions>
          </attributes>
        </NRCellRelation>
        <NRCellRelation xmlns="urn:3gpp:sa5:_3gpp-nr-nrm-nrcellrelation">
          <id>rel-2-to-1</id>
          <attributes>
            <nRFreqRelationRef>NRFreqRelation=intra-freq</nRFreqRelationRef>
            <adjacentNRCellRef>ManagedElement=ran1,GNBCUCPFunction=cucp1,NRCellCU=nrcellcu2</adjacentNRCellRef>
            <ocudu_nrcellrelation_mobility_extensions xmlns="urn:ocudu-gnbcucpfunction-mobility-extension:1.0">
              <report_config_refs>2</report_config_refs>
            </ocudu_nrcellrelation_mobility_extensions>
          </attributes>
        </NRCellRelation>
      </NRCellCU>

      <ocudu_gnbcucpfunction_mobility_extensions xmlns="urn:ocudu-gnbcucpfunction-mobility-extension:1.0">
        <trigger_handover_from_measurements>true</trigger_handover_from_measurements>
        <trigger_cho_on_ue_setup>true</trigger_cho_on_ue_setup>
        <cho_timeout_ms>15000</cho_timeout_ms>
        <report_configs>
          <report_cfg_id>1</report_cfg_id>
          <report_type>periodical</report_type>
          <report_interval_ms>1024</report_interval_ms>
          <periodic_ho_rsrp_offset_db>4</periodic_ho_rsrp_offset_db>
        </report_configs>
        <report_configs>
          <report_cfg_id>2</report_cfg_id>
          <report_type>event_triggered</report_type>
          <event_triggered_report_type>a3</event_triggered_report_type>
          <meas_trigger_quantity>rsrp</meas_trigger_quantity>
          <meas_trigger_quantity_offset_db>6</meas_trigger_quantity_offset_db>
          <hysteresis_db>0</hysteresis_db>
          <time_to_trigger_ms>100</time_to_trigger_ms>
          <report_interval_ms>1024</report_interval_ms>
          <t312>200</t312>
        </report_configs>
        <report_configs>
          <report_cfg_id>3</report_cfg_id>
          <report_type>event_triggered</report_type>
          <event_triggered_report_type>a5</event_triggered_report_type>
          <meas_trigger_quantity>rsrq</meas_trigger_quantity>
          <meas_trigger_quantity_threshold_db>-14</meas_trigger_quantity_threshold_db>
          <meas_trigger_quantity_threshold_2_db>-8</meas_trigger_quantity_threshold_2_db>
          <hysteresis_db>1</hysteresis_db>
          <time_to_trigger_ms>160</time_to_trigger_ms>
          <report_interval_ms>1024</report_interval_ms>
        </report_configs>
        <report_configs>
          <report_cfg_id>4</report_cfg_id>
          <report_type>cond_trigger</report_type>
          <event_triggered_report_type>d1</event_triggered_report_type>
          <distance_thresh_from_ref1_km>5.00</distance_thresh_from_ref1_km>
          <distance_thresh_from_ref2_km>3.00</distance_thresh_from_ref2_km>
          <hysteresis_location_km>0.10</hysteresis_location_km>
          <time_to_trigger_ms>100</time_to_trigger_ms>
          <ref_location1>
            <latitude>48.1350</latitude>
            <longitude>11.5820</longitude>
          </ref_location1>
          <ref_location2>
            <latitude>48.2000</latitude>
            <longitude>11.6500</longitude>
          </ref_location2>
        </report_configs>
        <report_configs>
          <report_cfg_id>5</report_cfg_id>
          <report_type>cond_trigger</report_type>
          <event_triggered_report_type>t1</event_triggered_report_type>
          <t1_thres>2026-05-12T12:00:00.000Z</t1_thres>
          <duration_s>10.0</duration_s>
        </report_configs>
      </ocudu_gnbcucpfunction_mobility_extensions>

      <EP_NgC xmlns="urn:3gpp:sa5:_3gpp-nr-nrm-ep">
        <id>ngc1</id>
        <attributes>
          <localAddress>
            <ipAddress>10.53.1.1</ipAddress>
            <vlanId>0</vlanId>
          </localAddress>
          <remoteAddress>10.53.1.2</remoteAddress>
        </attributes>
      </EP_NgC>

      <EP_F1C xmlns="urn:3gpp:sa5:_3gpp-nr-nrm-ep">
        <id>f1c1</id>
        <attributes>
          <!-- f1ap bind addresss -->
          <localAddress>
            <ipAddress>127.0.10.1</ipAddress>
            <vlanId>0</vlanId>
          </localAddress>
          <!-- f1ap DU peer address -->
          <remoteAddress>127.0.10.2</remoteAddress>
        </attributes>
      </EP_F1C>

      <ocudu_gnbcucpfunction_extensions xmlns="urn:ocudu-gnbcucpfunction-extension:1.0">
        <ocudu_log_extensions>
          <filename>/tmp/cu.log</filename>
          <all_level>warning</all_level>
        </ocudu_log_extensions>

        <ocudu_metrics_extensions>
          <periodicity>
            <cu_cp_report_period>1000</cu_cp_report_period>
          </periodicity>
          <layers>
            <enable_rrc>true</enable_rrc>
            <enable_ngap>true</enable_ngap>
          </layers>
        </ocudu_metrics_extensions>

        <ocudu_pcap_extensions>
          <ngap>
            <filename>/tmp/cucp_ngap.pcap</filename>
            <enable>false</enable>
          </ngap>
          <xnap>
            <filename>/tmp/cucp_xnap.pcap</filename>
            <enable>false</enable>
          </xnap>
          <e2ap_cu_cp>
            <filename>/tmp/cucp_e2ap.pcap</filename>
          </e2ap_cu_cp>
          <e2ap>
            <enable>false</enable>
          </e2ap>
          <f1ap>
            <filename>/tmp/cucp_f1ap.pcap</filename>
            <enable>false</enable>
          </f1ap>
          <e1ap>
            <filename>/tmp/cucp_e1ap.pcap</filename>
            <enable>false</enable>
          </e1ap>
        </ocudu_pcap_extensions>
      </ocudu_gnbcucpfunction_extensions>
  </GNBCUCPFunction>

  <GNBCUUPFunction xmlns="urn:3gpp:sa5:_3gpp-nr-nrm-gnbcuupfunction">
    <id>cuup1</id>
    <attributes>
      <priorityLabel>1</priorityLabel>
      <gNBId>1</gNBId>
      <gNBIdLength>24</gNBIdLength>
      <pLMNInfoList>
        <mcc>001</mcc>
        <mnc>01</mnc>
        <sd>ff:ff:ff</sd>
        <sst>1</sst>
      </pLMNInfoList>
    </attributes>

    <RRMPolicyRatio xmlns="urn:3gpp:sa5:_3gpp-nr-nrm-rrmpolicy">
      <id>rrm_policy1</id>
      <attributes>
        <resourceType>DRB</resourceType>
        <rRMPolicyMemberList>
          <mcc>001</mcc>
          <mnc>01</mnc>
          <sd>ff:ff:ff</sd>
          <sst>1</sst>
        </rRMPolicyMemberList>
        <rRMPolicyMaxRatio>100</rRMPolicyMaxRatio>
        <rRMPolicyMinRatio>0</rRMPolicyMinRatio>
        <rRMPolicyDedicatedRatio>0</rRMPolicyDedicatedRatio>
      </attributes>
    </RRMPolicyRatio>

    <EP_NgU xmlns="urn:3gpp:sa5:_3gpp-nr-nrm-ep">
      <id>ngu1</id>
      <attributes>
        <!-- NG-U bind addresss -->
        <localAddress>
          <ipAddress>127.0.0.1</ipAddress>
          <vlanId>0</vlanId>
        </localAddress>
        <!-- NG-U UPF peer address -->
        <remoteAddress>127.0.0.2</remoteAddress>
      </attributes>
    </EP_NgU>

    <EP_F1U xmlns="urn:3gpp:sa5:_3gpp-nr-nrm-ep">
      <id>f1u1</id>
      <attributes>
        <!-- f1u bind addresss -->
        <localAddress>
          <ipAddress>127.0.10.1</ipAddress>
          <vlanId>0</vlanId>
        </localAddress>
        <!-- f1u DU peer address -->
        <remoteAddress>127.0.10.2</remoteAddress>
      </attributes>
    </EP_F1U>

    <ocudu_gnbcuupfunction_extensions xmlns="urn:ocudu-gnbcuupfunction-extension:1.0">

      <ocudu_metrics_extensions>
        <enable_json>false</enable_json>
        <enable_log>true</enable_log>
        <periodicity>
          <cu_up_report_period>1000</cu_up_report_period>
        </periodicity>
        <layers>
          <enable_pdcp>true</enable_pdcp>
          <enable_e1ap>true</enable_e1ap>
        </layers>
      </ocudu_metrics_extensions>

      <ocudu_pcap_extensions>
        <n3>
          <filename>/tmp/cuup_n3.pcap</filename>
          <enable>false</enable>
        </n3>
        <e2ap_cu_up>
          <filename>/tmp/cuup_e2ap.pcap</filename>
        </e2ap_cu_up>
        <f1u>
          <filename>/tmp/cuup_f1u.pcap</filename>
          <enable>false</enable>
        </f1u>
      </ocudu_pcap_extensions>
    </ocudu_gnbcuupfunction_extensions>
  </GNBCUUPFunction>
</ManagedElement>
