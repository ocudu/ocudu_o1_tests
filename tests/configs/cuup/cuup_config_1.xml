<!-- Main CU-UP base config -->
<ManagedElement xmlns="urn:3gpp:sa5:_3gpp-common-managed-element">
  <id>ran1</id>
  <attributes>
    <priorityLabel>1</priorityLabel>
  </attributes>

  <GNBCUUPFunction xmlns="urn:3gpp:sa5:_3gpp-nr-nrm-gnbcuupfunction">
    <id>cuup1</id>
    <attributes>
      <priorityLabel>1</priorityLabel>
      <gNBId>1</gNBId>
      <gNBIdLength>24</gNBIdLength>
      <pLMNInfoList>
        <mcc>001</mcc>
        <mnc>01</mnc>
        <sd>ff:ff:ff</sd>
        <sst>1</sst>
      </pLMNInfoList>
    </attributes>

    <RRMPolicyRatio xmlns="urn:3gpp:sa5:_3gpp-nr-nrm-rrmpolicy">
      <id>rrm_policy1</id>
      <attributes>
        <resourceType>DRB</resourceType>
        <rRMPolicyMemberList>
          <mcc>001</mcc>
          <mnc>01</mnc>
          <sd>ff:ff:ff</sd>
          <sst>1</sst>
        </rRMPolicyMemberList>
        <rRMPolicyMaxRatio>100</rRMPolicyMaxRatio>
        <rRMPolicyMinRatio>0</rRMPolicyMinRatio>
        <rRMPolicyDedicatedRatio>0</rRMPolicyDedicatedRatio>
      </attributes>
    </RRMPolicyRatio>

    <EP_E1 xmlns="urn:3gpp:sa5:_3gpp-nr-nrm-ep">
      <id>e11</id>
      <attributes>
        <!-- e1ap bind addresss -->
        <localAddress>
          <ipAddress>127.0.20.2</ipAddress>
          <vlanId>0</vlanId>
        </localAddress>
        <!-- e1ap CU-CP peer address -->
        <remoteAddress>127.0.20.1</remoteAddress>
      </attributes>
    </EP_E1>

    <EP_NgU xmlns="urn:3gpp:sa5:_3gpp-nr-nrm-ep">
      <id>ngu1</id>
      <attributes>
        <!-- NG-U bind addresss -->
        <localAddress>
          <ipAddress>127.0.0.1</ipAddress>
          <vlanId>0</vlanId>
        </localAddress>
        <!-- NG-U UPF peer address -->
        <remoteAddress>127.0.0.2</remoteAddress>
      </attributes>
    </EP_NgU>

    <EP_F1U xmlns="urn:3gpp:sa5:_3gpp-nr-nrm-ep">
      <id>f1u1</id>
      <attributes>
        <!-- f1u bind addresss -->
        <localAddress>
          <ipAddress>127.0.10.1</ipAddress>
          <vlanId>0</vlanId>
        </localAddress>
        <!-- f1u DU peer address -->
        <remoteAddress>127.0.10.2</remoteAddress>
      </attributes>
    </EP_F1U>

    <ocudu_gnbcuupfunction_extensions xmlns="urn:ocudu-gnbcuupfunction-extension:1.0">
      <ocudu_log_extensions>
        <filename>/tmp/cuup.log</filename>
        <all_level>warning</all_level>
      </ocudu_log_extensions>

      <ocudu_metrics_extensions>
        <enable_json>false</enable_json>
        <enable_log>true</enable_log>
        <periodicity>
          <cu_up_report_period>1000</cu_up_report_period>
        </periodicity>
        <layers>
          <enable_pdcp>true</enable_pdcp>
          <enable_e1ap>true</enable_e1ap>
        </layers>
      </ocudu_metrics_extensions>

      <ocudu_pcap_extensions>
        <n3>
          <filename>/tmp/cuup_n3.pcap</filename>
          <enable>false</enable>
        </n3>
        <e2ap_cu_up>
          <filename>/tmp/cuup_e2ap.pcap</filename>
        </e2ap_cu_up>
        <e2ap>
          <enable>false</enable>
        </e2ap>
        <e1ap>
          <filename>/tmp/cuup_e1ap.pcap</filename>
          <enable>false</enable>
        </e1ap>
        <f1u>
          <filename>/tmp/cuup_f1u.pcap</filename>
          <enable>false</enable>
        </f1u>
      </ocudu_pcap_extensions>
    </ocudu_gnbcuupfunction_extensions>
  </GNBCUUPFunction>
</ManagedElement>
