<!-- Main CU-UP base config -->
<ManagedElement xmlns="urn:3gpp:sa5:_3gpp-common-managed-element">
  <id>ran1</id>
  <attributes>
    <priorityLabel>1</priorityLabel>
  </attributes>

  <GNBCUUPFunction xmlns="urn:3gpp:sa5:_3gpp-nr-nrm-gnbcuupfunction">
    <id>cuup1</id>
    <attributes>
      <priorityLabel>1</priorityLabel>
      <gNBCUUPId>1</gNBCUUPId>
      <gNBId>1</gNBId>
      <gNBIdLength>24</gNBIdLength>
      <pLMNInfoList>
        <mcc>001</mcc>
        <mnc>01</mnc>
        <sd>ff:ff:ff</sd>
        <sst>1</sst>
      </pLMNInfoList>
    </attributes>

    <RRMPolicyRatio xmlns="urn:3gpp:sa5:_3gpp-nr-nrm-rrmpolicy">
      <id>rrm_policy1</id>
      <attributes>
        <resourceType>DRB</resourceType>
        <rRMPolicyMemberList>
          <mcc>001</mcc>
          <mnc>01</mnc>
          <sd>ff:ff:ff</sd>
          <sst>1</sst>
        </rRMPolicyMemberList>
        <rRMPolicyMaxRatio>100</rRMPolicyMaxRatio>
        <rRMPolicyMinRatio>0</rRMPolicyMinRatio>
        <rRMPolicyDedicatedRatio>0</rRMPolicyDedicatedRatio>
      </attributes>
    </RRMPolicyRatio>

    <EP_E1 xmlns="urn:3gpp:sa5:_3gpp-nr-nrm-ep">
      <id>e11</id>
      <attributes>
        <!-- e1ap bind addresss -->
        <localAddress>
          <ipAddress>127.0.20.2</ipAddress>
          <vlanId>0</vlanId>
        </localAddress>
        <!-- e1ap CU-CP peer address -->
        <remoteAddress>127.0.20.1</remoteAddress>
      </attributes>
    </EP_E1>

    <EP_NgU xmlns="urn:3gpp:sa5:_3gpp-nr-nrm-ep">
      <id>ngu1</id>
      <attributes>
        <!-- NG-U bind addresss -->
        <localAddress>
          <ipAddress>127.0.0.1</ipAddress>
          <vlanId>0</vlanId>
        </localAddress>
        <!-- no remoteAddress: the N3/NG-U peer (UPF) is provided by the core via signaling -->
      </attributes>
    </EP_NgU>

    <EP_F1U xmlns="urn:3gpp:sa5:_3gpp-nr-nrm-ep">
      <id>f1u1</id>
      <attributes>
        <!-- f1u bind addresss -->
        <localAddress>
          <ipAddress>127.0.10.1</ipAddress>
          <vlanId>0</vlanId>
        </localAddress>
        <!-- no remoteAddress: the F1-U peer is learned via F1AP signaling -->
        <!-- f1u GTP-U bind/peer UDP ports (default 2152 per TS 29.281) -->
        <ocudu_ep_f1u_extensions xmlns="urn:ocudu-gnbcuupfunction-extension:1.0">
          <bind_port>2152</bind_port>
          <peer_port>2152</peer_port>
        </ocudu_ep_f1u_extensions>
      </attributes>
    </EP_F1U>

    <ocudu_gnbcuupfunction_extensions xmlns="urn:ocudu-gnbcuupfunction-extension:1.0">
      <ocudu_log_extensions>
        <filename>/tmp/cuup.log</filename>
        <all_level>warning</all_level>
      </ocudu_log_extensions>

      <ocudu_metrics_extensions>
        <enable_json>false</enable_json>
        <enable_log>true</enable_log>
        <periodicity>
          <cu_up_report_period>1000</cu_up_report_period>
        </periodicity>
        <layers>
          <enable_pdcp>true</enable_pdcp>
          <enable_e1ap>true</enable_e1ap>
        </layers>
      </ocudu_metrics_extensions>

      <ocudu_pcap_extensions>
        <n3>
          <filename>/tmp/cuup_n3.pcap</filename>
          <enable>false</enable>
        </n3>
        <e2ap_cu_up>
          <filename>/tmp/cuup_e2ap.pcap</filename>
        </e2ap_cu_up>
        <e2ap>
          <enable>false</enable>
        </e2ap>
        <e1ap>
          <filename>/tmp/cuup_e1ap.pcap</filename>
          <enable>false</enable>
        </e1ap>
        <f1u>
          <filename>/tmp/cuup_f1u.pcap</filename>
          <enable>false</enable>
        </f1u>
      </ocudu_pcap_extensions>

      <ocudu_remote_control_extensions>
        <enabled>true</enabled>
        <bind_addr>0.0.0.0</bind_addr>
        <port>8001</port>
      </ocudu_remote_control_extensions>

      <ocudu_gnbcuupfunction_testmode_extensions>
        <enable>false</enable>
        <integrity_enable>true</integrity_enable>
        <ciphering_enable>true</ciphering_enable>
        <nea_algo>2</nea_algo>
        <nia_algo>2</nia_algo>
        <ue_ambr>40000000000</ue_ambr>
        <attach_detach_period>0</attach_detach_period>
        <reestablish_period>0</reestablish_period>
        <f1u_peer_address>127.0.10.2</f1u_peer_address>
        <nof_ues>1</nof_ues>
      </ocudu_gnbcuupfunction_testmode_extensions>
    </ocudu_gnbcuupfunction_extensions>
  </GNBCUUPFunction>
</ManagedElement>
