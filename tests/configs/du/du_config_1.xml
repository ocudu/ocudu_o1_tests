    <EP_F1C xmlns="urn:3gpp:sa5:_3gpp-nr-nrm-ep">
      <id>f1c1</id>
      <attributes>
        <!-- f1c bind addresss -->
        <localAddress>  
          <ipAddress>10.11.12.112</ipAddress>
          <vlanId>100</vlanId>
        </localAddress>
        <!-- f1c connect address (the gNB-CU-CP). An IPv4/IPv6 literal, or in Kubernetes
             a DNS service name that the O1 adapter resolves before writing the gNB
             config, e.g.: <remoteAddress>cucp.default.svc.cluster.local</remoteAddress> -->
        <remoteAddress>10.11.12.113</remoteAddress>
      </attributes>
    </EP_F1C>
    <EP_F1U xmlns="urn:3gpp:sa5:_3gpp-nr-nrm-ep">
      <id>f1u1</id>
      <attributes>
        <!-- f1u bind addresss -->
        <localAddress>
          <ipAddress>10.11.13.112</ipAddress>
          <vlanId>101</vlanId>
        </localAddress>
        <!-- no remoteAddress: the F1-U peer is learned via F1AP signaling -->
        <!-- f1u GTP-U bind/peer UDP ports (default 2152 per TS 29.281) -->
        <ocudu_ep_f1u_extensions xmlns="urn:ocudu-gnbdufunction-extension:1.0">
          <bind_port>2152</bind_port>
          <peer_port>2152</peer_port>
        </ocudu_ep_f1u_extensions>
      </attributes>
    </EP_F1U>

    <ocudu_gnbdufunction_extensions xmlns="urn:ocudu-gnbdufunction-extension:1.0">
      <ocudu_ru_sdr_extensions>
        <device_driver>uhd</device_driver>
