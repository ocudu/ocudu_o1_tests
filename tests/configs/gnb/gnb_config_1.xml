    <EP_F1C xmlns="urn:3gpp:sa5:_3gpp-nr-nrm-ep">
      <id>f1c1</id>
      <attributes>
        <!-- f1c bind addresss -->
        <localAddress>  
          <ipAddress>10.11.12.112</ipAddress>
          <vlanId>100</vlanId>
        </localAddress>
        <!-- f1c connect ip4v/ipv6 address -->
        <remoteAddress>10.11.12.113</remoteAddress>
      </attributes>
    </EP_F1C>
    <EP_F1U xmlns="urn:3gpp:sa5:_3gpp-nr-nrm-ep">
      <id>f1u1</id>
      <attributes>
        <!-- f1u bind addresss -->
        <localAddress>
          <ipAddress>10.11.13.112</ipAddress>
          <vlanId>101</vlanId>
        </localAddress>
        <!-- f1u connect ip4v/ipv6 address -->
        <remoteAddress>10.11.13.113</remoteAddress>
      </attributes>
    </EP_F1U>

    <ocudu_gnbdufunction_extensions xmlns="urn:ocudu-gnbdufunction-extension:1.0">
      <ocudu_gnbdufunction_testmode_extensions>
        <enabled>true</enabled>
        <rnti>44</rnti>
        <ri>1</ri>
        <cqi>15</cqi>
        <nof_ues>1</nof_ues>
        <pdsch_active>true</pdsch_active>
        <pusch_active>true</pusch_active>
      </ocudu_gnbdufunction_testmode_extensions>
      <ocudu_log_extensions>
        <filename>/tmp/gnb.log</filename>
        <all_level>warning</all_level>
      </ocudu_log_extensions>
      <ocudu_hal_extensions>
        <eal_args>--lcores (0-1)@(0-11)</eal_args>
      </ocudu_hal_extensions>

      <ocudu_remote_control_extensions>
        <enabled>true</enabled>
        <bind_addr>0.0.0.0</bind_addr>
      </ocudu_remote_control_extensions>

      <ocudu_metrics_extensions>
        <autostart_stdout_metrics>true</autostart_stdout_metrics>
        <enable_json>false</enable_json>
        <enable_log>true</enable_log>
        <periodicity>
          <du_report_period>1000</du_report_period>
          <cu_up_report_period>1000</cu_up_report_period>
          <cu_cp_report_period>1000</cu_cp_report_period>
        </periodicity>
        <layers>
          <enable_ru>true</enable_ru>
          <enable_sched>true</enable_sched>
          <enable_rlc>false</enable_rlc>
          <enable_mac>false</enable_mac>
          <enable_pdcp>false</enable_pdcp>
          <enable_du_low>false</enable_du_low>
        </layers>
      </ocudu_metrics_extensions>

      <ocudu_pcap_extensions>
        <rlc>
          <filename>/tmp/gnb_rlc.pcap</filename>
          <rb_type>all</rb_type>
          <enable>false</enable>
        </rlc>
        <mac>
          <filename>/tmp/gnb_mac.pcap</filename>
          <type>udp</type>
          <enable>false</enable>
        </mac>
        <f1ap>
          <filename>/tmp/gnb_f1ap.pcap</filename>
          <enable>false</enable>
        </f1ap>
        <f1u>
          <filename>/tmp/gnb_f1u.pcap</filename>
          <enable>false</enable>
        </f1u>
        <e2ap_du>
          <filename>/tmp/gnb_e2ap.pcap</filename>
        </e2ap_du>
        <e2ap>
          <enable>false</enable>
        </e2ap>
      </ocudu_pcap_extensions>

    </ocudu_gnbdufunction_extensions>

  </GNBDUFunction>
</ManagedElement>