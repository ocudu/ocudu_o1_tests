<!-- Main CU/DU base config -->
<ManagedElement xmlns="urn:3gpp:sa5:_3gpp-common-managed-element">
  <id>ran1</id>
  <attributes>
    <priorityLabel>1</priorityLabel>
  </attributes>
  
  <GNBCUCPFunction xmlns="urn:3gpp:sa5:_3gpp-nr-nrm-gnbcucpfunction">
      <id>cucp1</id>

      <attributes>
        <gNBId>1</gNBId>
        <gNBIdLength>24</gNBIdLength>
        <gNBCUName>ocuducu1</gNBCUName>
        <pLMNId>
          <mcc>001</mcc>
          <mnc>01</mnc>
        </pLMNId>
        <priorityLabel>1</priorityLabel>
        <qceIdMappingInfoList>
          <idx>0</idx>
          <qoECollectionEntityAddress>0.0.0.0</qoECollectionEntityAddress>
          <qoECollectionEntityIdentity>unused</qoECollectionEntityIdentity>
          <pLMNTarget>
            <mcc>001</mcc>
            <mnc>01</mnc>
          </pLMNTarget>
        </qceIdMappingInfoList>
      </attributes>

      <RRMPolicyRatio xmlns="urn:3gpp:sa5:_3gpp-nr-nrm-rrmpolicy">
        <id>rrm_policy1</id>
        <attributes>
          <resourceType>DRB</resourceType>
          <rRMPolicyMemberList>
            <mcc>001</mcc>
            <mnc>01</mnc>
            <sd>ff:ff:ff</sd>
            <sst>1</sst>
          </rRMPolicyMemberList>
          <rRMPolicyMaxRatio>100</rRMPolicyMaxRatio>
          <rRMPolicyMinRatio>0</rRMPolicyMinRatio>
          <rRMPolicyDedicatedRatio>0</rRMPolicyDedicatedRatio>
        </attributes>
      </RRMPolicyRatio>

      <PerfMetricJob>
        <id>defaulttrace</id>
        <attributes>
          <administrativeState>UNLOCKED</administrativeState>
          <performanceMetrics>DRB.MaxActiveUeDl</performanceMetrics>
          <granularityPeriod>1</granularityPeriod>
          <!--
          <fileReportingPeriod>10</fileReportingPeriod>
          <fileLocation>/tmp/metrics.json</fileLocation>
          -->
          <streamTarget>http://192.168.2.42:9560/json</streamTarget>
        </attributes>
      </PerfMetricJob>

      <!-- No cell specific CU config required
      <NRCellCU xmlns="urn:3gpp:sa5:_3gpp-nr-nrm-nrcellcu">
        <id>nrcell1</id>
        <attributes>
         <cellLocalId>100</cellLocalId>
           <pLMNInfoList>
             <mcc>001</mcc>
             <mnc>01</mnc>
             <sd>ff:ff:ff</sd>
             <sst>1</sst>
           </pLMNInfoList>
           <priorityLabel>1</priorityLabel>
        </attributes>
      </NRCellCU>
      -->

      <EP_NgC xmlns="urn:3gpp:sa5:_3gpp-nr-nrm-ep">
        <id>ngc1</id>
        <attributes>
          <localAddress>
            <ipAddress>10.53.1.1</ipAddress>
            <vlanId>0</vlanId>
          </localAddress>
          <remoteAddress>10.53.1.2</remoteAddress>
        </attributes>
      </EP_NgC>

      <ocudu_gnbcucpfunction_extensions xmlns="urn:ocudu-gnbcucpfunction-extension:1.0">
        <ocudu_pcap_extensions>
          <ngap>
            <filename>/tmp/gnb_ngap.pcap</filename>
            <enable>false</enable>
          </ngap>
          <xnap>
            <filename>/tmp/gnb_xnap.pcap</filename>
            <enable>false</enable>
          </xnap>
          <e1ap>
            <filename>/tmp/gnb_e1ap.pcap</filename>
            <enable>false</enable>
          </e1ap>
        </ocudu_pcap_extensions>
      </ocudu_gnbcucpfunction_extensions>

  </GNBCUCPFunction>
  
  <GNBCUUPFunction xmlns="urn:3gpp:sa5:_3gpp-nr-nrm-gnbcuupfunction">
    <id>cuup1</id>
    <attributes>
      <priorityLabel>1</priorityLabel>
      <gNBId>1</gNBId>
      <gNBIdLength>24</gNBIdLength>
      <pLMNInfoList>
        <mcc>001</mcc>
        <mnc>01</mnc>
        <sd>ff:ff:ff</sd>
        <sst>1</sst>
      </pLMNInfoList>
    </attributes>

    <RRMPolicyRatio xmlns="urn:3gpp:sa5:_3gpp-nr-nrm-rrmpolicy">
      <id>rrm_policy1</id>
      <attributes>
        <resourceType>DRB</resourceType>
        <rRMPolicyMemberList>
          <mcc>001</mcc>
          <mnc>01</mnc>
          <sd>ff:ff:ff</sd>
          <sst>1</sst>
        </rRMPolicyMemberList>
        <rRMPolicyMaxRatio>100</rRMPolicyMaxRatio>
        <rRMPolicyMinRatio>0</rRMPolicyMinRatio>
        <rRMPolicyDedicatedRatio>0</rRMPolicyDedicatedRatio>
      </attributes>
    </RRMPolicyRatio>

    <ocudu_gnbcuupfunction_extensions xmlns="urn:ocudu-gnbcuupfunction-extension:1.0">
      <ocudu_pcap_extensions>
        <n3>
          <filename>/tmp/gnb_n3.pcap</filename>
          <enable>false</enable>
        </n3>
      </ocudu_pcap_extensions>
    </ocudu_gnbcuupfunction_extensions>
  </GNBCUUPFunction>
  
  <GNBDUFunction xmlns="urn:3gpp:sa5:_3gpp-nr-nrm-gnbdufunction">
    <id>du1</id>
    <attributes>
      <gNBId>411</gNBId>
      <gNBIdLength>23</gNBIdLength>
      <gNBDUId>3</gNBDUId>
      <priorityLabel>1</priorityLabel>
    </attributes>
    <RRMPolicyRatio xmlns="urn:3gpp:sa5:_3gpp-nr-nrm-rrmpolicy">
      <id>rrm_policy1</id>
      <attributes>
        <resourceType>PRB</resourceType>
        <rRMPolicyMemberList>
          <mcc>001</mcc>
          <mnc>01</mnc>
          <sd>ff:ff:ff</sd>
          <sst>1</sst>
        </rRMPolicyMemberList>
        <rRMPolicyMaxRatio>100</rRMPolicyMaxRatio>
        <rRMPolicyMinRatio>0</rRMPolicyMinRatio>
        <rRMPolicyDedicatedRatio>0</rRMPolicyDedicatedRatio>
      </attributes>
    </RRMPolicyRatio>
    <NRCellDU xmlns="urn:3gpp:sa5:_3gpp-nr-nrm-nrcelldu">
      <id>nrcelldu1</id>
      <RRMPolicyRatio xmlns="urn:3gpp:sa5:_3gpp-nr-nrm-rrmpolicy">
        <id>rrm_policy1</id>
        <attributes>
          <resourceType>PRB</resourceType>
          <rRMPolicyMemberList>
            <mcc>001</mcc>
            <mnc>01</mnc>
            <sd>ff:ff:ff</sd>
            <sst>1</sst>
          </rRMPolicyMemberList>
          <rRMPolicyMaxRatio>100</rRMPolicyMaxRatio>
          <rRMPolicyMinRatio>0</rRMPolicyMinRatio>
          <rRMPolicyDedicatedRatio>0</rRMPolicyDedicatedRatio>
        </attributes>
      </RRMPolicyRatio>
      <attributes>
        <priorityLabel>1</priorityLabel>
        <cellLocalId>0</cellLocalId>
        <administrativeState>UNLOCKED</administrativeState>
        <pLMNInfoList>
          <mcc>001</mcc>
          <mnc>01</mnc>
          <sd>ff:ff:ff</sd>
          <sst>1</sst>
        </pLMNInfoList>
        <nPNIdentityList>
          <idx>0</idx>
          <plmnid>
            <mcc>001</mcc>
            <mnc>01</mnc>
          </plmnid>
          <cAGIdList>unused</cAGIdList>
          <nIDList>unused</nIDList>
        </nPNIdentityList>
        <nRPCI>1</nRPCI>
        <nRTAC>7</nRTAC>
        <arfcnDL>640000</arfcnDL>
        <arfcnUL>640000</arfcnUL>
        <bSChannelBwDL>100</bSChannelBwDL>
        <bSChannelBwUL>100</bSChannelBwUL>
        <rimRSMonitoringStartTime>1970-01-01T00:00:00Z</rimRSMonitoringStartTime>
        <rimRSMonitoringStopTime>1970-01-01T00:00:00Z</rimRSMonitoringStopTime>
        <rimRSMonitoringWindowDuration>1</rimRSMonitoringWindowDuration>
        <rimRSMonitoringWindowStartingOffset>0</rimRSMonitoringWindowStartingOffset>
        <rimRSMonitoringWindowPeriodicity>24</rimRSMonitoringWindowPeriodicity>
        <rimRSMonitoringOccasionInterval>1</rimRSMonitoringOccasionInterval>
        <rimRSMonitoringOccasionStartingOffset>0</rimRSMonitoringOccasionStartingOffset>
        <victimSetRef>RimRSSet=unused</victimSetRef>
        <aggressorSetRef>RimRSSet=unused</aggressorSetRef>
        <ssbFrequency>3000000</ssbFrequency>
        <ssbPeriodicity>10</ssbPeriodicity>
        <ssbSubCarrierSpacing>30</ssbSubCarrierSpacing>
        <ssbOffset>0</ssbOffset>
        <ssbDuration>1</ssbDuration>
        <nRSectorCarrierRef>SCarr=not_used</nRSectorCarrierRef>
          <ocudu_nrcelldu_extensions xmlns="urn:ocudu-nrcelldu-extension:1.0">
            <ocudu_nrcelldu_ofh_extensions>
              <network_interface>lo</network_interface>
              <ru_mac_addr>00:11:22:33:44:55</ru_mac_addr>
              <du_mac_addr>aa:bb:cc:dd:ee:ff</du_mac_addr>
              <vlan_tag_cp>100</vlan_tag_cp>
              <vlan_tag_up>100</vlan_tag_up>
              <prach_port_id>[4, 5]</prach_port_id>
              <dl_port_id>[0, 1]</dl_port_id>
              <ul_port_id>[0, 1]</ul_port_id>
              <enable_promiscuous>false</enable_promiscuous>
              <check_link_status>false</check_link_status>
              <t1a_max_cp_dl>350</t1a_max_cp_dl>
              <t1a_min_cp_dl>200</t1a_min_cp_dl>
              <t1a_max_cp_ul>350</t1a_max_cp_ul>
              <t1a_min_cp_ul>200</t1a_min_cp_ul>
              <t1a_max_up>500</t1a_max_up>
              <t1a_min_up>0</t1a_min_up>
              <ta4_max>500</ta4_max>
              <ta4_min>0</ta4_min>
              <compr_method_ul>BLOCK_FLOATING_POINT</compr_method_ul>
              <compr_bitwidth_ul>9</compr_bitwidth_ul>
              <compr_method_dl>BLOCK_FLOATING_POINT</compr_method_dl>
              <compr_bitwidth_dl>9</compr_bitwidth_dl>
              <compr_method_prach>BLOCK_FLOATING_POINT</compr_method_prach>
              <compr_bitwidth_prach>9</compr_bitwidth_prach>
              <enable_dl_static_compr_hdr>STATIC</enable_dl_static_compr_hdr>
              <enable_ul_static_compr_hdr>STATIC</enable_ul_static_compr_hdr>
              <is_prach_cp_enabled>true</is_prach_cp_enabled>
              <ignore_ecpri_payload_size>false</ignore_ecpri_payload_size>
              <ignore_ecpri_seq_id>false</ignore_ecpri_seq_id>
              <iq_scaling>5.0</iq_scaling>
            </ocudu_nrcelldu_ofh_extensions>
            <ocudu_nrcelldu_base_extensions>
              <nof_antennas_dl>2</nof_antennas_dl>
              <nof_antennas_ul>2</nof_antennas_ul>
              <common_scs>KHZ_30</common_scs>
            </ocudu_nrcelldu_base_extensions>            
            <ocudu_nrcelldu_ssb_extensions>
              <ssb_block_power_dbm>-16</ssb_block_power_dbm>
            </ocudu_nrcelldu_ssb_extensions>
            <ocudu_nrcelldu_prach_extensions>
              <prach_config_index>159</prach_config_index>
              <prach_root_sequence_index>1</prach_root_sequence_index>
            </ocudu_nrcelldu_prach_extensions>
            <ocudu_nrcelldu_pdsch_extensions>
              <mcs_table>qam64</mcs_table>
            </ocudu_nrcelldu_pdsch_extensions>
          </ocudu_nrcelldu_extensions>
      </attributes>
    </NRCellDU>

